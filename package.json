{
  "name": "xiabing-demo-001",
  "version": "1.0.0",
  "description": "Minimal full-stack task demo",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "test:e2e": "playwright test e2e.spec.js --reporter=line",
    "ci": "bash scripts/ci.sh",
    "test:coverage": "c8 --reporter=text-summary --reporter=json-summary --check-coverage --lines 70 node --test",
    "ci:strict": "npm run test:coverage && npm run test:e2e:ci",
    "test:e2e:ci": "CI=1 playwright test e2e.spec.js --reporter=line"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "c8": "^11.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
